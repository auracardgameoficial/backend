{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "dev": "nodemon server.js",
    "test:watch": "node --test --watch",
    "lint": "npx --yes eslint@9 .",
    "format": "npx --yes prettier@3 . --write",
    "format:check": "npx --yes prettier@3 . --check",
    "test:coverage": "node --experimental-test-coverage --test-coverage-lines=45 --test-coverage-functions=45 --test-coverage-branches=35 --test --test-concurrency=1 tests/*.test.js",
    "check": "npm run lint && npm run format:check && npm test && npm run coverage:check",
    "lint:fix": "npx --yes eslint@9 . --fix",
    "coverage:check": "npm run test:coverage"
  },
  "keywords": [],
